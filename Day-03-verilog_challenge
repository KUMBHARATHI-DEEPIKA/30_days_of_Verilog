// Code your design here
module comp(
    input a, b,
    output reg less_than,
    output reg great_than,
    output reg equal
);

always @(*) begin
    if (a < b) begin
        less_than = 1'b1;
        great_than = 1'b0;
        equal = 1'b0;
    end
    else if (a > b) begin
        less_than = 1'b0;
        great_than = 1'b1;
        equal = 1'b0;
    end
    else begin
        less_than = 1'b0;
        great_than = 1'b0;
        equal = 1'b1;
    end
end

endmodule



