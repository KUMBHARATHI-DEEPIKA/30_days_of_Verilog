//Design code
module half_adder(
    input A,
    input B,
    output Sum,
    output Carry
);
assign Sum   = A ^ B;
assign Carry = A & B;
endmodule



//testbench code
module half_adder_tb;
reg A;
reg B;
wire Sum;
wire Carry;
// Instantiate the Half Adder
half_adder uut (
    .A(A),
    .B(B),
    .Sum(Sum),
    .Carry(Carry)
);
initial begin
    $display("A B | Sum Carry");
    $monitor("%b %b |  %b    %b", A, B, Sum, Carry);
    A = 0; B = 0;
    #10;
    A = 0; B = 1;
    #10;
    A = 1; B = 0;
    #10;
    A = 1; B = 1;
    #10;
    $finish;
end

endmodule
